{
  "request": {
    "method": "GET",
    "urlPathPattern": "/playlists/([a-zA-Z0-9]+)/items",
    "queryParameters": {
      "offset": { "matches": "[0-9]+" },
      "limit": { "equalTo": "1" },
      "fields": { "equalTo": "total,limit,offset,items(item(id,name,href,popularity,is_local,artists(id,name)))" },
      "additional_types": { "equalTo": "track" }
    }
  },
  "response": {
    "status": 200,
    "transformers": ["response-template"],
    "bodyFileName": "playlist_items_{{request.pathSegments.[1]}}_page_{{math request.query.offset '+' 1}}.json",
    "headers": {
      "Content-Type": "application/json"
    }
  }
}
