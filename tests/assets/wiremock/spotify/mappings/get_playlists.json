{
  "request": {
    "method": "GET",
    "urlPath": "/me/playlists",
    "queryParameters": {
      "limit": { "equalTo": "1" },
      "offset": { "matches": "[0-9]+" }
    }
  },
  "response": {
    "status": 200,
    "transformers": ["response-template"],
    "bodyFileName": "playlists_page_{{math request.query.offset '+' 1}}.json",
    "headers": {
      "Content-Type": "application/json"
    }
  }
}
